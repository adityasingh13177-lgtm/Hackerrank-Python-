if __name__ == '__main__':
    students = []
    for _ in range(int(input())):
        name = input()
        score = float(input())
        students.append([name,score])
        
    scores = sorted(list(set([x[1]for x in students])))
    second_lowest_scores = scores[1]
    
    low_finalists = [x[0]for x in students if x[1]== second_lowest_scores]
    low_finalists.sort()
    for name in low_finalists:
        print(name)
